# Payload
PAYLOAD_SECRET=replace-with-long-random-string

# Database connection.
#   - Leave empty for local dev → uses SQLite at ./payload-local.db
#   - Set to `postgresql://...` in production (Neon: https://console.neon.tech)
DATABASE_URI=

# Token required to call POST /api/seed
SEED_TOKEN=replace-with-random-string

# Public site URL (used for sitemaps, OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
